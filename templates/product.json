verflow: hidden;\n    border-radius: 8px;\n    background: #f3f4f6;\n  }\n  .review-card__img-container img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n  .review-card__img-label {\n    position: absolute;\n    bottom: 4px;\n    left: 4px;\n    background: rgba(255, 255, 255, 0.9);\n    color: #272759;\n    font-size: 8px;\n    font-weight: 800;\n    padding: 2px 6px;\n    border-radius: 4px;\n    text-transform: uppercase;\n  }\n  /* ----------------------------------------- */\n\n  .review-card__text {\n    font-size: 13px;\n    color: #4b5563;\n    line-height: 1.6;\n    margin-bottom: 10px;\n  }\n  .review-card__date {\n    font-size: 11px;\n    color: #9ca3af;\n    margin-top: auto;\n  }\n</style>\n\n<div id=\"avis\" class=\"reviews-carousel\">\n  <h3 class=\"reviews-carousel__title\">Résultats de nos clients</h3>\n  <div class=\"reviews-carousel__track\">\n\n    <div class=\"review-card\">\n      <div class=\"review-card__header\">\n        <div class=\"review-card__avatar\">M</div>\n        <div>\n          <div class=\"review-card__name\">Marie L.</div>\n          <div class=\"review-card__badge\">✓ Achat vérifié</div>\n        </div>\n      </div>\n      <div class=\"review-card__stars\">★★★★★</div>\n      \n      <div class=\"review-card__images\">\n        <div class=\"review-card__img-container\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0929/1441/8049/files/532ece22d5e39e685e72faa517ce961a.jpg?v=1773155138\" >\n       \n        </div>\n\n      </div>\n\n      <div class=\"review-card__text\">Après ma grossesse  Je perdait mes cheveux par poignées 😭 Ça fait 2 mois que j'utilise le roller et j'ai déjà plein de petits baby hair qui camouflent tout hahah enfin.</div>\n      <div class=\"review-card__date\">Il y a 3 jours</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-card__header\">\n        <div class=\"review-card__avatar\">T</div>\n        <div>\n          <div class=\"review-card__n