      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "{% comment %}\n\n  ============================================\n\n  CUSTOM LIQUID — \"Ils parlent de nous\" (Logos Presse)\n\n  ============================================\n\n  Bandeau avec logos médias en grayscale.\n\n  Hover pour révéler la couleur.\n\n{% endcomment %}\n\n \n\n<style>\n\n  .press-logos {\n\n    padding: 24px 16px;\n\n    text-align: center;\n\n    margin: 20px 0;\n\n  }\n\n  .press-logos__title {\n\n    font-size: 11px;\n\n    font-weight: 600;\n\n    text-transform: uppercase;\n\n    letter-spacing: 1.5px;\n\n    color: #9ca3af;\n\n    margin-bottom: 20px;\n\n  }\n\n  .press-logos__grid {\n\n    display: flex;\n\n    justify-content: center;\n\n    align-items: center;\n\n    gap: 32px;\n\n    flex-wrap: wrap;\n\n  }\n\n  .press-logo {\n\n    font-size: 18px;\n\n    font-weight: 800;\n\n    color: #d1d5db;\n\n    text-transform: uppercase;\n\n    letter-spacing: 1px;\n\n    transition: all 0.3s ease;\n\n    cursor: default;\n\n    user-select: none;\n\n  }\n\n  .press-logo:hover {\n\n    color: #374151;\n\n    transform: scale(1.05);\n\n  }\n\n  .press-logo--italic {\n\n    font-style: italic;\n\n  }\n\n  .press-logo--serif {\n\n    font-family: Georgia, 'Times New Roman', serif;\n\n  }\n\n  .press-logos__divider {\n\n    width: 1px;\n\n    height: 24px;\n\n    background: #e5e7eb;\n\n  }\n\n  @media (max-width: 749px) {\n\n    .press-logos__grid { gap: 20px; }\n\n    .press-logo { font-size: 14px; }\n\n    .press-logos__divider { display: none; }\n\n  }\n\n</style>\n\n \n\n<div class=\"press-logos\">\n\n  <div class=\"press-logos__title\">Ils parlent de nous</div>\n\n  <div class=\"press-logos__grid\">\n\n    {%- comment -%} Remplacez par vos vrais logos en <img> si vous les avez {%- endcomment -%}\n\n\n    <span class=\"press-logo press-logo--italic\">Vogue</span>\n\n\n\n    <span class=\"press-logos__divider\"></span>\n\n    <span class=\"press-logo press-logo--serif\">Elle</span>\n\n\n  </div>\n\n</div>",
