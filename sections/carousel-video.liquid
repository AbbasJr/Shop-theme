{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding-block-start }}px;
    padding-bottom: {{ section.settings.padding-block-end }}px;
  }

  /* Gestion de la disposition (Flexbox) basée sur les réglages */
  .section-container-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    flex-direction: {{ section.settings.content_direction }};
    gap: {{ section.settings.gap }}px;
    
    /* Alignement horizontal */
    {% if section.settings.content_direction == 'row' %}
      justify-content: {{ section.settings.horizontal_alignment }};
      align-items: {{ section.settings.vertical_alignment }};
    {% else %}
      align-items: {{ section.settings.horizontal_alignment_flex_direction_column }};
      justify-content: {{ section.settings.vertical_alignment_flex_direction_column }};
    {% endif %}
  }

  /* Responsive Mobile */
  @media screen and (max-width: 750px) {
    {% if section.settings.vertical_on_mobile %}
      .section-container-{{ section.id }} {
        flex-direction: column !important;
        align-items: center; /* Centrage par défaut sur mobile */
      }
    {% endif %}
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="{% if section.settings.section_width == 'page-width' %}page-width{% else %}full-width{% endif %}">
    
    <div class="section-container-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="section-block" {{ block.shopify_attributes }}>
          
          {%- case block.type -%}
            
            {%- when 'heading' -%}
              <h2 class="{{ block.settings.type_preset }}" style="text-align: {{ block.settings.alignment }}">
                {{ block.settings.text | default: "Titre" }}
              </h2>

            {%- when 'text' -%}
              <div class="rte" style="text-align: {{ block.settings.alignment }}; max-width: {{ block.settings.max_width }}">
                {{ block.settings.text }}
              </div>

            {%- when 'button' -%}
              <div style="text-align: center; width: 100%;">
                <a href="{{ block.settings.link }}" class="button {{ block.settings.style_class }}">
                  {{ block.settings.label }}
                </a>
              </div>

            {%- when 'image' -%}
               {% if block.settings.image != blank %}
                 {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
               {% endif %}

            {%- when 'accordion' -%}
              <details>
                <summary>{{ block.settings.heading | default: "Accordéon" }}</summary>
                <div class="accordion-content">
                  Contenu de l'accordéon à implémenter ici.
                </div>
              </details>

            {%- else -%}
              <p style="background: #f4f4f4; padding: 10px;">
                Le type de bloc <strong>{{ block.type }}</strong> doit être configuré dans le code Liquid.
              </p>

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>